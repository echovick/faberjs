{
  "name": "@faber-js/channels",
  "version": "1.1.3",
  "description": "FaberJS real-time WebSocket channels — first-class pub/sub, presence, and broadcasting",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "require": "./dist/client.js",
      "import": "./dist/client.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "websocket",
    "channels",
    "realtime",
    "presence",
    "broadcast"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^",
    "@faber-js/http": "workspace:^",
    "@fastify/websocket": "^11.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "ioredis": "^5.3.2"
  },
  "peerDependencies": {
    "ioredis": "^5.3.2"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
