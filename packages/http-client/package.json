{
  "name": "@faber-js/http-client",
  "version": "1.4.1",
  "description": "FaberJS HTTP client — fluent fetch wrapper with retries, faking, and recording",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "http",
    "fetch",
    "client",
    "http-client"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
