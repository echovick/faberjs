{
  "name": "@forgejs/console",
  "version": "0.0.1",
  "description": "ForgeJS CLI — code generation, migration runner, queue worker, and REPL",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "forgejs",
    "framework",
    "cli",
    "console",
    "artisan"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
