{
  "name": "@faber-js/console",
  "version": "1.0.19",
  "description": "FaberJS CLI — code generation, migration runner, queue worker, and REPL",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "faber": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "cli",
    "console",
    "artisan"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^",
    "@faber-js/http": "workspace:^",
    "@faber-js/orm": "workspace:^",
    "@faber-js/router": "workspace:^",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  }
}
