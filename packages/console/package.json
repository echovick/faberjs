{
  "name": "@faberjs/console",
  "version": "0.0.1",
  "description": "FaberJS CLI — code generation, migration runner, queue worker, and REPL",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "faber": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "cli",
    "console",
    "artisan"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faberjs/core": "workspace:*",
    "@faberjs/http": "workspace:*",
    "@faberjs/orm": "workspace:*",
    "@faberjs/router": "workspace:*",
    "commander": "^12.1.0"
  }
}
