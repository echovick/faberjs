{
  "name": "@faber-js/orm",
  "version": "1.5.0",
  "description": "FaberJS Eloquent-like ActiveRecord ORM with query builder, relationships, and migrations",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "orm",
    "database",
    "activerecord",
    "migrations"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^",
    "knex": "^3.1.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependencies": {
    "sql.js": "^1.12.0"
  },
  "peerDependenciesMeta": {
    "sql.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "better-sqlite3": "^9.4.0",
    "@types/better-sqlite3": "^7.6.8",
    "sql.js": "^1.12.0"
  }
}
