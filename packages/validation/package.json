{
  "name": "@faber-js/validation",
  "version": "1.0.26",
  "description": "FaberJS request validation with fluent rules, FormRequest, and auto-error responses",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "validation",
    "rules",
    "form-request"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^",
    "@faber-js/http": "workspace:^"
  },
  "devDependencies": {
    "@faber-js/orm": "workspace:^",
    "better-sqlite3": "^9.4.0",
    "@types/better-sqlite3": "^7.6.8",
    "knex": "^3.1.0"
  }
}
