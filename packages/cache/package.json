{
  "name": "@faber-js/cache",
  "version": "1.1.7",
  "description": "FaberJS cache abstraction — Redis, database, and in-memory drivers with locks and rate limiting",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "cache",
    "redis",
    "memory",
    "rate-limiting"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^"
  },
  "peerDependencies": {
    "ioredis": ">=5"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  }
}
