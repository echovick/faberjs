{
  "name": "@faber-js/schema",
  "version": "1.1.5",
  "description": "FaberJS schema-first model declarations — one definition generates migrations, types, validation, OpenAPI, and test factories",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "schema",
    "orm",
    "validation",
    "openapi"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^",
    "@faber-js/orm": "workspace:^",
    "@faber-js/validation": "workspace:^",
    "@faker-js/faker": "^9.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "better-sqlite3": "^9.4.0",
    "@types/better-sqlite3": "^7.6.8",
    "knex": "^3.1.0"
  }
}
