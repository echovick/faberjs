{
  "name": "@faber-js/http",
  "version": "1.1.5",
  "description": "FaberJS HTTP kernel, Request/Response abstraction, and middleware pipeline",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "http",
    "middleware",
    "request",
    "response"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^",
    "@fastify/multipart": "^10.0.0",
    "fastify": "^5.8.3",
    "picocolors": "^1.1.1"
  }
}
