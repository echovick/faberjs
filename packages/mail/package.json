{
  "name": "@faber-js/mail",
  "version": "1.1.3",
  "description": "FaberJS mail — Nodemailer-backed Mailable classes with Mail facade, faking, and queued mail",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "mail",
    "email",
    "nodemailer",
    "smtp"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^"
  },
  "peerDependencies": {
    "nodemailer": ">=6"
  },
  "peerDependenciesMeta": {
    "nodemailer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0"
  }
}
