{
  "name": "@forgejs/router",
  "version": "0.0.1",
  "description": "ForgeJS HTTP routing engine with resource routes, route groups, and route model binding",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "forgejs",
    "framework",
    "router",
    "http",
    "routing"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
