{
  "name": "@faber-js/support",
  "version": "1.1.3",
  "description": "FaberJS support — Collection, Str, Arr, Pipeline, and utility helpers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "support",
    "collection",
    "string",
    "helpers"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
