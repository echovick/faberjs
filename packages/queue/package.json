{
  "name": "@faberjs/queue",
  "version": "0.0.1",
  "description": "FaberJS background job dispatching and queue workers backed by BullMQ",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "queue",
    "jobs",
    "bullmq",
    "workers"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faberjs/core": "workspace:*"
  }
}
