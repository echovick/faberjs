{
  "name": "@faber-js/queue",
  "version": "1.0.28",
  "description": "FaberJS background job dispatching and queue workers backed by BullMQ",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "faberjs",
    "framework",
    "queue",
    "jobs",
    "bullmq",
    "workers"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@faber-js/core": "workspace:^",
    "bullmq": "^5.12.0"
  },
  "devDependencies": {
    "ioredis-mock": "^8.9.0",
    "@types/ioredis-mock": "^8.2.5"
  }
}
